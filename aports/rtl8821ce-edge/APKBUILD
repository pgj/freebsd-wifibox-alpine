# Maintainer: Gabor Pali <pali.gabor@gmail.com>

pkgname='rtl8821ce-edge'
pkgver=20251013
_kern_maj=6
_kern_min=19
_kern_pcs=11
_kern_rel=0
_drv_rel=0
pkgrel=$(printf "%02d%02d%03d%02d%02d" $_kern_maj $_kern_min $_kern_pcs $_kern_rel $_drv_rel)
_gitrev='4e6b887f0d8c4091a4df9da9fcead9a8294b41ad'
pkgdesc='Driver for Realtek 8821CE, an 802.11ac device (edge)'
arch='x86_64'
url='https://github.com/tomaspinho/rtl8821ce'
license='GPL-2.0'
makedepends="linux-edge-dev~$_kern_maj.$_kern_min.$_kern_pcs-r$_kern_rel xz"
depends="linux-edge~$_kern_maj.$_kern_min.$_kern_pcs-r$_kern_rel"
install=
options="!check !strip"
source="https://github.com/tomaspinho/rtl8821ce/archive/${_gitrev}.zip"

_kver="$_kern_maj.$_kern_min.$_kern_pcs-$_kern_rel-edge"
_kbase="/lib/modules/${_kver}"
_srcdir="$srcdir/rtl8821ce-$_gitrev"

build() {
  make -C "$_srcdir" -j8 KVER="$_kver"
}

package() {
  xz -C crc32 "$_srcdir"/*.ko
  install -p -D -m 644 "$_srcdir"/*.ko.xz -t "$pkgdir"/lib/modules/"$_kver"/kernel/drivers/net/wireless/realtek/rtl8821ce
}

sha512sums="
f4c3aae87c58ea3cdadc6c28f4daeeb0ff314b7da633331d90c6e9c77d694d42e8a80eed9e06cd45d32229dbc67d65d88c8b7ddebf7ef325e05ca72c51373f53  4e6b887f0d8c4091a4df9da9fcead9a8294b41ad.zip
"
